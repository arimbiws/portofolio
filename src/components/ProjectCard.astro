---
import { Image } from "astro:assets";
const { project } = Astro.props;

const coverImage = Array.isArray(project.images) && project.images.length > 0 ? project.images[0] : project.images;
---

<div
  onclick={`window.location.href='/projects/${project.slug}'`}
  class="group cursor-pointer relative flex flex-col bg-white dark:bg-slate-900/50 border border-slate-200 dark:border-slate-800 rounded-2xl overflow-hidden shadow-sm hover:shadow-2xl hover:border-primary/50 dark:hover:border-accent/50 transition-all duration-500 hover:-translate-y-2"
>
  <a href={`/projects/${project.slug}`} class="absolute inset-0 z-0" aria-label={`View details for ${project.title}`}></a>

  <div class="h-52 overflow-hidden shrink-0 relative">
    <div class="absolute inset-0 bg-primary/20 dark:bg-primary-900/50 opacity-0 group-hover:opacity-100 transition-opacity duration-300 z-10"></div>
    <Image transition:name={`img-${project.slug}`} src={coverImage} alt={project.title} class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-700 ease-out" />
  </div>
  <div class="p-6 flex flex-col flex-grow z-20 bg-white dark:bg-slate-900">
    <h4 transition:name={`title-${project.slug}`} class="text-xl font-bold mb-3 dark:text-white group-hover:text-primary dark:group-hover:text-accent transition-colors">
      {project.title}
    </h4>
    <p class="text-slate-600 dark:text-slate-400 text-sm mb-6 flex-grow leading-relaxed">{project.shortDescription}</p>

    <div class="flex flex-wrap gap-2 mb-6">
      {
        project.techStack
          .slice(0, 5)
          .map((tech: string) => <span class="text-xs font-mono bg-slate-100 dark:bg-slate-800 text-slate-700 dark:text-slate-300 px-2.5 py-1 rounded-md border border-slate-200 dark:border-slate-700">{tech}</span>)
      }
      {project.techStack.length > 5 && <span class="text-xs font-mono bg-transparent text-slate-500 px-1 py-1">+{project.techStack.length - 5}</span>}
    </div>

    <div class="flex justify-between items-center z-20 pt-3 pointer-events-auto relative mt-auto border-t border-slate-100 dark:border-slate-800/50">
      {
        project.demoLink && project.demoLink !== "#" && (
          <a
            href={project.demoLink}
            target="_blank"
            onclick="event.stopPropagation();"
            class="text-xs font-medium bg-primary/10 text-primary dark:bg-secondary/20 dark:text-accent hover:bg-secondary hover:text-white dark:hover:bg-primary dark:hover:text-accent px-3 py-1.5 rounded-lg transition-colors flex items-center gap-1"
          >
            Live Demo
            <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
            </svg>
          </a>
        )
      }
      <a href={`/projects/${project.slug}`} onclick="event.stopPropagation();" class="ml-auto text-sm font-semibold text-primary dark:text-accent hover:underline underline-offset-4 flex items-center gap-1">
        Details
        <svg class="w-4 h-4 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3"></path>
        </svg>
      </a>
    </div>
  </div>
</div>
