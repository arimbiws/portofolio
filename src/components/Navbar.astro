---
import { Image } from "astro:assets";
import myLogo from "../assets/logo.svg";
---

<nav class="fixed w-full top-0 z-50 bg-primary dark:bg-slate-950/80 backdrop-blur-md border-b border-secondary/50 dark:border-slate-800 transition-colors duration-300 shadow-md">
  <div class="max-w-6xl mx-auto px-6 py-4 flex justify-between items-center">
    <a href="/" class="flex items-center gap-2">
      <Image src={myLogo} alt="Logo" height={40} class="object-contain" />
    </a>

    <div class="flex items-center space-x-5 md:space-x-8 text-sm">
      <a href="/" class="nav-link hidden sm:block font-medium text-white/80 dark:text-slate-300 hover:text-white dark:hover:text-accent transition">Home</a>
      <a href="/projects" class="nav-link hidden sm:block font-medium text-white/80 dark:text-slate-300 hover:text-white dark:hover:text-accent transition">Projects</a>
      <a href="/#skills" class="nav-link hidden sm:block font-medium text-white/80 dark:text-slate-300 hover:text-white dark:hover:text-accent transition">Skills</a>
      <a href="/#contact" class="nav-link hidden sm:block font-medium text-white/80 dark:text-slate-300 hover:text-white dark:hover:text-accent transition">Contact</a>

      <div class="w-px h-4 bg-white/30 dark:bg-slate-700 hidden sm:block"></div>

      <a href="https://linkedin.com" target="_blank" class="hover:text-white dark:hover:text-blue-400 transition" aria-label="LinkedIn">
        <svg class="w-4 h-4 text-white/80 dark:text-slate-300" fill="currentColor" viewBox="0 0 24 24"
          ><path
            d="M19 0h-14c-2.761 0-5 2.239-5 5v14c0 2.761 2.239 5 5 5h14c2.762 0 5-2.239 5-5v-14c0-2.761-2.238-5-5-5zm-11 19h-3v-11h3v11zm-1.5-12.268c-.966 0-1.75-.79-1.75-1.764s.784-1.764 1.75-1.764 1.75.79 1.75 1.764-.783 1.764-1.75 1.764zm13.5 12.268h-3v-5.604c0-3.368-4-3.113-4 0v5.604h-3v-11h3v1.765c1.396-2.586 7-2.777 7 2.476v6.759z"
          ></path></svg
        >
      </a>
      <a href="https://github.com" target="_blank" class="hover:text-white dark:hover:text-white transition" aria-label="GitHub">
        <svg class="w-5 h-5 text-white/80 dark:text-slate-300" fill="currentColor" viewBox="0 0 24 24"
          ><path
            fill-rule="evenodd"
            d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z"
            clip-rule="evenodd"></path></svg
        >
      </a>

      <button id="theme-toggle" class="p-2 -mr-2 rounded-md hover:bg-secondary dark:hover:bg-slate-800 transition text-white/80 hover:text-white dark:text-slate-300" aria-label="Toggle Dark Mode">
        <svg class="w-5 h-5 dark:hidden" fill="currentColor" viewBox="0 0 20 20"><path d="M17.293 13.293A8 8 0 016.707 2.707a8.001 8.001 0 1010.586 10.586z"></path></svg>
        <svg class="w-5 h-5 hidden dark:block text-yellow-400" fill="currentColor" viewBox="0 0 20 20"
          ><path
            fill-rule="evenodd"
            d="M10 2a1 1 0 011 1v1a1 1 0 11-2 0V3a1 1 0 011-1zm4 8a4 4 0 11-8 0 4 4 0 018 0zm-.464 4.95l.707.707a1 1 0 001.414-1.414l-.707-.707a1 1 0 00-1.414 1.414zm2.12-10.607a1 1 0 010 1.414l-.706.707a1 1 0 11-1.414-1.414l.707-.707a1 1 0 011.414 0zM17 11a1 1 0 100-2h-1a1 1 0 100 2h1zm-7 4a1 1 0 011 1v1a1 1 0 11-2 0v-1a1 1 0 011-1zM5.05 6.464A1 1 0 106.465 5.05l-.708-.707a1 1 0 00-1.414 1.414l.707.707zm1.414 8.486l-.707.707a1 1 0 01-1.414-1.414l.707-.707a1 1 0 011.414 1.414zM4 11a1 1 0 100-2H3a1 1 0 000 2h1z"
            clip-rule="evenodd"></path></svg
        >
      </button>
    </div>
  </div>
</nav>

<script>
  document.addEventListener("astro:page-load", () => {
    const themeToggle = document.getElementById("theme-toggle");
    const handleToggleClick = () => {
      const element = document.documentElement;
      element.classList.toggle("dark");
      const isDark = element.classList.contains("dark");
      localStorage.setItem("theme", isDark ? "dark" : "light");
    };
    themeToggle?.removeEventListener("click", handleToggleClick);
    themeToggle?.addEventListener("click", handleToggleClick);

    const navLinks = document.querySelectorAll(".nav-link");
    const currentPath = window.location.pathname;

    const setActiveClass = (activeLinkHref: string) => {
      navLinks.forEach((link) => {
        const href = link.getAttribute("href");

        if (href === activeLinkHref || (activeLinkHref.startsWith("/projects") && href === "/projects")) {
          link.classList.remove("font-medium", "text-white/80", "dark:text-slate-300");
          link.classList.add("font-bold", "underline", "underline-offset-8", "text-white", "dark:text-accent");
        } else {
          link.classList.add("font-medium", "text-white/80", "dark:text-slate-300");
          link.classList.remove("font-bold", "underline", "underline-offset-8", "text-white", "dark:text-accent");
        }
      });
    };

    if (currentPath === "/" || currentPath === "") {
      const sections = document.querySelectorAll("section[id]");

      const observerOptions = {
        root: null,
        rootMargin: "-40% 0px -40% 0px",
        threshold: 0,
      };

      const observer = new IntersectionObserver((entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            const id = entry.target.id;
            const targetHref = id === "home" ? "/" : `/#${id}`;
            setActiveClass(targetHref);
          }
        });
      }, observerOptions);

      sections.forEach((section) => {
        observer.observe(section);
      });
    } else {
      setActiveClass(currentPath);
    }
  });
</script>
