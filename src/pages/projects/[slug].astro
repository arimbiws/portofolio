---
import Layout from "../../layouts/Layout.astro";
import { Image } from "astro:assets";
import { projects } from "../../data/projects.js";

export function getStaticPaths() {
  return projects.map((project) => ({
    params: { slug: project.slug },
    props: { project },
  }));
}

const { project } = Astro.props;
---

<Layout title={`${project.title} | John Doe`} description={project.shortDescription}>
  <main class="max-w-6xl mx-auto px-6">
    <div class="mb-8">
      <button onclick="history.back()" class="inline-flex items-center text-sm font-mono text-primary dark:text-accent hover:underline underline-offset-4 group bg-transparent border-none cursor-pointer">
        <svg class="w-4 h-4 mr-2 group-hover:-translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24"
          ><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"></path></svg
        >
        Back to Projects
      </button>
    </div>

    <h1 transition:name={`title-${project.slug}`} class="text-4xl md:text-5xl font-extrabold mb-6 text-slate-900 dark:text-white tracking-tight">
      {project.title}
    </h1>

    <div class="flex flex-wrap gap-2 mb-10">
      {project.techStack.map((tech) => <span class="text-sm font-mono bg-slate-100 dark:bg-slate-800 text-slate-700 dark:text-slate-300 px-3 py-1 rounded-full border border-slate-200 dark:border-slate-700">{tech}</span>)}
    </div>

    <div class="rounded-2xl overflow-hidden mb-12 shadow-xl border border-slate-200 dark:border-slate-800">
      <Image transition:name={`img-${project.slug}`} src={project.image} alt={project.title} class="w-full object-contain max-h-[500px]" />
    </div>

    <article class="prose prose-lg prose-slate dark:prose-invert max-w-none mb-12">
      <h2 class="text-2xl font-bold mb-4 dark:text-white">About the Project</h2>
      {project.fullDescription.map((paragraph) => <p class="text-slate-600 dark:text-slate-300 leading-relaxed mb-4">{paragraph}</p>)}
    </article>

    <div class="flex flex-wrap gap-4 pb-12">
      {
        project.githubLink && project.githubLink !== "#" && (
          <a
            href={project.githubLink}
            target="_blank"
            class="border-2 border-slate-300 dark:border-slate-700 px-8 py-3 rounded-lg font-medium hover:border-primary dark:hover:border-accent hover:text-primary dark:hover:text-accent transition dark:text-white flex items-center"
          >
            View Source
            <svg class="w-5 h-5 ml-2" fill="currentColor" viewBox="0 0 24 24">
              <path
                fill-rule="evenodd"
                d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z"
                clip-rule="evenodd"
              />
            </svg>
          </a>
        )
      }
      {
        project.demoLink && project.demoLink !== "#" && (
          <a href={project.demoLink} target="_blank" class="bg-primary hover:bg-secondary dark:bg-accent dark:hover:bg-secondary text-white px-8 py-3 rounded-lg font-medium transition shadow-md flex items-center">
            Live Demo
            <svg class="w-4 h-4 ml-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
            </svg>
          </a>
        )
      }
    </div>
  </main>
</Layout>
